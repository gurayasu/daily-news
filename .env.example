# ローカル開発用の環境変数定義ファイル
# このファイルはGitにコミットしないこと（.gitignoreに含まれています）
# GitHub Actionsではこのファイルは不要です（Secretsを使用）

# Gemini APIキー（https://aistudio.google.com/ で取得）
GEMINI_API_KEY=your_gemini_api_key_here

# （省略可）Geminiモデル。省略時は gemini-2.5-flash-lite を使用
GEMINI_MODEL=gemini-2.5-flash-lite

# 送信元Gmailアドレス
GMAIL_USER=your-email@gmail.com

# Gmailアプリパスワード（2段階認証を有効にしてから発行）
# 取得手順: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 送信先メールアドレス（複数の場合はカンマ区切り）
EMAIL_RECIPIENTS=recipient@gmail.com
